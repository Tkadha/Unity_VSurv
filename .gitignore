############################################################
# Unity
############################################################
[Ll]ibrary/
[Tt]emp/
[Oo]bj/
[Bb]uild/
[Bb]uilds/
[Ll]ogs/
[Uu]ser[Ss]ettings/

# Asset import cache
/[Aa]ssets/AssetStoreTools*

# Memory captures / recordings (can be huge)
/[Mm]emoryCaptures/
/[Rr]ecordings/

# Unity auto-generated meta for some builds
*.pidb
*.booproj
*.svd

# Unity crash reports
sysinfo.txt

# Gradle / Android
.gradle/
**/build/
!/[Aa]ssets/**/build/

# Addressables cache (optional; safe to ignore)
[Aa]ssets/[Aa]ddressable[Aa]ssets[Dd]ata/*/*.bin*

# IL2CPP
Il2cppBuildCache/

############################################################
# Visual Studio / MSBuild
############################################################
.vs/
*.user
*.userosscache
*.suo
*.cache
*.dbmdl
*.opendb
*.VC.db
*.VC.VC.opendb

# Visual Studio build outputs
[Dd]ebug/
[Rr]elease/
x64/
x86/
[Bb]in/
[Oo]bj/

# Test results
[Tt]est[Rr]esult*/
*.trx

# NuGet
*.nupkg
# packages/      # (Unity에서는 보통 사용 안 함. 필요할 때만 주석 해제)
# **/packages/*

############################################################
# Rider / JetBrains
############################################################
.idea/
*.sln.iml

############################################################
# VS Code
############################################################
.vscode/
*.code-workspace

############################################################
# OS / Misc
############################################################
.DS_Store
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/
*.tmp
*.log

############################################################
# Optional (Unity Collaborate / Cloud)
############################################################
.collabignore
